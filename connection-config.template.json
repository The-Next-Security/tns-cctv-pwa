    "pool": {
      "max_size": 10
    }
  },
  "production": {
    "host": "YOUR_PROD_HOST",
    "port": 3306,
    "username": "YOUR_PROD_USER",
    "password": "YOUR_PROD_PASSWORD",
    "database": "YOUR_PROD_DATABASE",
    "pool": {
      "max_size": 20
    }
  }
}
